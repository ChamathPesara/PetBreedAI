<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F8">

    <!-- Top App Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#EEF2F8"
        android:elevation="0dp"
        android:layout_marginTop="10dp"
        app:contentInsetStart="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_paw"
                app:tint="#1A56DB" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PetBreedAI"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0A1628"
                android:fontFamily="@font/alexandria_semibold"
                android:layout_marginStart="8dp" />

            <ImageButton
                android:id="@+id/btnLogOut"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Log Out"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp"
                app:tint="#1A56DB" />

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Pet Image with confidence badge -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <ImageView
                    android:id="@+id/resultPetImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_pet" />

                <!-- Confidence Badge -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFFCC">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_verified"
                            android:layout_marginEnd="6dp"
                            app:tint="#1A56DB" />

                        <TextView
                            android:id="@+id/tvConfidenceBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="93% Confidence"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#0A1628"
                            android:fontFamily="@font/alexandria_semibold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <!-- Result Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Animal Type label + icon row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAnimalType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/alexandria_semibold"
                                android:letterSpacing="0.08"
                                android:text="ANIMAL TYPE: DOG"
                                android:textColor="#4A5568"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvBreedName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Golden\nRetriever"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:textColor="#0A1628"
                                android:fontFamily="@font/alexandria_semibold"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            app:cardCornerRadius="25dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E0F7F5">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_paw"
                                app:tint="#0D6B5E" />

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- Confidence Score -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Confidence Score"
                            android:textSize="14sp"
                            android:textColor="#4A5568"
                            android:fontFamily="@font/alexandria" />

                        <TextView
                            android:id="@+id/tvConfidencePercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="93%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A56DB"
                            android:fontFamily="@font/alexandria_semibold" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/confidenceProgressBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="93"
                        android:progressDrawable="@drawable/progress_confidence"
                        android:layout_marginTop="8dp" />

                    <!-- AI Description -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="match_parent"
                            android:background="#1A56DB"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_info_card"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_info"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp"
                                app:tint="#1A56DB" />

                            <TextView
                                android:id="@+id/tvAiDescription"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="The AI identified distinctive features including the dense water-repellent coat and friendly facial structure."
                                android:textSize="13sp"
                                android:textStyle="italic"
                                android:textColor="#2D3748"
                                android:fontFamily="@font/alexandria" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Probability Ranking Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/layoutRanking"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Probability Ranking"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#0A1628"
                        android:fontFamily="@font/alexandria_semibold" />

                    <!-- Rank 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_rank_item"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#1A56DB"
                            android:layout_marginEnd="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="1"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:gravity="center"
                                android:fontFamily="@font/alexandria_semibold" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/tvRank1Name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/alexandria_semibold"
                            android:text="Golden Retriever"
                            android:textColor="#0A1628"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRank1Conf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/alexandria_semibold"
                            android:text="93%"
                            android:textColor="#1A56DB"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Rank 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:paddingHorizontal="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2F8"
                            android:layout_marginEnd="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="2"
                                android:textSize="14sp"
                                android:textColor="#4A5568"
                                android:gravity="center"
                                android:fontFamily="@font/alexandria" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/tvRank2Name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/alexandria"
                            android:text="Labrador Retriever"
                            android:textColor="#2D3748"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvRank2Conf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/alexandria"
                            android:text="4%"
                            android:textColor="#4A5568"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- Rank 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:paddingHorizontal="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2F8"
                            android:layout_marginEnd="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="3"
                                android:textSize="14sp"
                                android:textColor="#4A5568"
                                android:gravity="center"
                                android:fontFamily="@font/alexandria" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/tvRank3Name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/alexandria"
                            android:text="Nova Scotia Duck Tolling\nRetriever"
                            android:textColor="#2D3748"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvRank3Conf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/alexandria"
                            android:text="2%"
                            android:textColor="#4A5568"
                            android:textSize="15sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Breed Tip -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/cardBreedTip"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FDEBD0"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#C97A20"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lightbulb"
                            app:tint="#FFFFFF" />

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Breed Tip"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#7B4000"
                            android:fontFamily="@font/alexandria_semibold" />

                        <TextView
                            android:id="@+id/tvBreedTip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Golden Retrievers are highly social. Ensure they get at least 1 hour of active exercise daily to maintain their well-being."
                            android:textSize="13sp"
                            android:textColor="#7B4000"
                            android:fontFamily="@font/alexandria"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Try Another Image Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnTryAnother"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A56DB"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_camera"
                        android:layout_marginEnd="10dp"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try Another Image"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/alexandria_semibold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save to History link -->
            <TextView
                android:id="@+id/btnSaveHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save to History"
                android:textSize="14sp"
                android:textColor="#2D3748"
                android:gravity="center"
                android:fontFamily="@font/alexandria"
                android:layout_marginTop="14dp"
                android:paddingVertical="8dp"
                android:foreground="?attr/selectableItemBackground" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconTint="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>