<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F8">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEF2F8"
        android:layout_marginTop="10dp"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#EEF2F8"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_paw"
                    app:tint="#1A56DB" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PetBreedAI"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0A1628"
                    android:fontFamily="@font/alexandria_semibold"
                    android:layout_marginStart="8dp" />

                <ImageButton
                    android:id="@+id/btnLogOut"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Log Out"
                    app:tint="#1A56DB" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>
    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- Decorative blobs background (use a FrameLayout to layer) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Background blobs ImageView -->
                <ImageView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_paw"
                    android:alpha="0.5"
                    android:scaleType="fitEnd" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Hero Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alexandria_semibold"
                        android:lineSpacingMultiplier="1.4"
                        android:text="Identify Any\nBreed"
                        android:textColor="#0A1628"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alexandria_semibold"
                        android:text="Instantly !!!"
                        android:textColor="#1A56DB"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Our advanced AI helps you discover the story behind every paw print. Just point, snap, and learn."
                        android:textSize="14sp"
                        android:textColor="#4A5568"
                        android:fontFamily="@font/alexandria"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </FrameLayout>

            <!-- Action Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginTop="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Take Photo Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnTakePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A56DB"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="20dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_camera"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Take Photo"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/alexandria_semibold"
                                android:layout_marginStart="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textSize="18sp"
                                android:textColor="#FFFFFF" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Upload from Gallery Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnUploadGallery"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2F8"
                        android:layout_marginTop="12dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="20dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_image"
                                app:tint="#2D3748" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Upload from Gallery"
                                android:textSize="16sp"
                                android:textColor="#2D3748"
                                android:fontFamily="@font/alexandria_semibold"
                                android:layout_marginStart="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textSize="18sp"
                                android:textColor="#4A5568" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Accuracy Info Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_info"
                            android:layout_marginEnd="10dp"
                            app:tint="#1A56DB" />

                        <View
                            android:layout_width="3dp"
                            android:layout_height="36dp"
                            android:background="#1A56DB"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="98.4% accuracy for most common domestic breeds."
                            android:textSize="13sp"
                            android:textColor="#4A5568"
                            android:fontFamily="@font/alexandria" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom two cards row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Latest Scan Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLatestScan"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#B0C4DE"
                    android:layout_marginEnd="8dp"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:id="@+id/latestImage"
                            android:src="@drawable/placeholder_latest_scan"
                            android:scaleType="centerCrop"
                            android:alpha="0.6" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LATEST SCAN"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/alexandria_semibold" />

                            <TextView
                                android:id="@+id/latestBreed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/alexandria_semibold"
                                android:text="Golden Retriever"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- Quick Tip Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FDEBD0"
                    android:layout_marginStart="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_lightbulb"
                                app:tint="#C97A20" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="Quick tip: Ensure good lighting for best results."
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B4000"
                            android:fontFamily="@font/alexandria_semibold"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#C8D0DC"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Footer text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="POWERED BY PETBREED AI NEURAL ENGINE"
                android:textSize="10sp"
                android:textColor="#8A9BB0"
                android:fontFamily="@font/alexandria"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="150dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconTint="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>