<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F8">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEF2F8"
        android:layout_marginTop="10dp"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#EEF2F8"
            app:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_paw"
                    app:tint="#1A56DB" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PetBreedAI"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0A1628"
                    android:fontFamily="@font/alexandria_semibold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Hero Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Decorative paw blob -->
                <ImageView
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-20dp"
                    android:src="@drawable/ic_paw"
                    android:alpha="0.7"
                    android:scaleType="fitEnd" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alexandria_semibold"
                        android:lineSpacingMultiplier="1.1"
                        android:text="Welcome"
                        android:textColor="#0A1628"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/alexandria_semibold"
                        android:text="Back !!!"
                        android:textColor="#1A56DB"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sign in to continue identifying your favourite breeds."
                        android:textSize="14sp"
                        android:textColor="#4A5568"
                        android:fontFamily="@font/alexandria"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </FrameLayout>

            <!-- Login Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginTop="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Username Field Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Username"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:fontFamily="@font/alexandria_semibold"
                        android:layout_marginBottom="6dp" />

                    <!-- Username Input -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2F8">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_account_circle"
                                android:layout_marginEnd="10dp"
                                app:tint="#4A5568" />

                            <EditText
                                android:id="@+id/etUsername"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:hint="Enter your username"
                                android:textSize="14sp"
                                android:textColor="#0A1628"
                                android:textColorHint="#8A9BB0"
                                android:fontFamily="@font/alexandria"
                                android:background="@null"
                                android:inputType="text"
                                android:imeOptions="actionNext"
                                android:singleLine="true" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Password Field Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:fontFamily="@font/alexandria_semibold"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp" />

                    <!-- Password Input -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2F8">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_lock"
                                android:layout_marginEnd="10dp"
                                app:tint="#4A5568" />

                            <EditText
                                android:id="@+id/etPassword"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:hint="Enter your password"
                                android:textSize="14sp"
                                android:textColor="#0A1628"
                                android:textColorHint="#8A9BB0"
                                android:fontFamily="@font/alexandria"
                                android:background="@null"
                                android:inputType="textPassword"
                                android:imeOptions="actionDone"
                                android:singleLine="true" />

                            <!-- Toggle Password Visibility -->
                            <ImageButton
                                android:id="@+id/btnTogglePassword"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_visibility_off"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Toggle password visibility"
                                app:tint="#8A9BB0" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Login Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A56DB"
                        android:layout_marginTop="24dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingHorizontal="20dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_login"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="Sign In"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/alexandria_semibold"
                                android:layout_marginStart="12dp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Exit Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnExitCard"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2F8"
                        android:layout_marginTop="12dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:id="@+id/btnExit"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="20dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_close"
                                app:tint="#2D3748" />

                            <TextView
                                android:layout_width="35dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/alexandria_semibold"
                                android:text="Exit"
                                android:textColor="#2D3748"
                                android:textSize="16sp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Info Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_info"
                            android:layout_marginEnd="10dp"
                            app:tint="#1A56DB" />

                        <View
                            android:layout_width="3dp"
                            android:layout_height="36dp"
                            android:background="#1A56DB"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your data is encrypted and never shared with third parties."
                            android:textSize="13sp"
                            android:textColor="#4A5568"
                            android:fontFamily="@font/alexandria" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="#C8D0DC"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Sign Up Link -->
            <LinearLayout
                android:id="@+id/btnSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center"
                android:foreground="?attr/selectableItemBackground"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textSize="14sp"
                    android:textColor="#4A5568"
                    android:fontFamily="@font/alexandria" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textSize="14sp"
                    android:textColor="#1A56DB"
                    android:textStyle="bold"
                    android:fontFamily="@font/alexandria_semibold" />

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="POWERED BY PETBREED AI NEURAL ENGINE"
                android:textSize="10sp"
                android:textColor="#8A9BB0"
                android:fontFamily="@font/alexandria"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>